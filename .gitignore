# ==========================================
# DocenTrack - Global .gitignore
# ==========================================

# --- ENTORNOS VIRTUALES ---
backend/.venv/
backend/venv/
backend/env/
.venv/
venv/
env/
ENV/

# --- VARIABLES DE ENTORNO ---
.env
.env.local
.env.production
.env.development
.env.*.local
*.env
!.env.example

# --- BASES DE DATOS LOCALES ---
*.sqlite3
*.db
*.sqlite3-journal

# --- PYTHON / DJANGO ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/staticfiles/
backend/media/
backend/local_settings.py
backend/*.pyc
backend/**/__pycache__/
*.egg-info/
dist/
build/

# --- NODE / REACT ---
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.env.local
frontend/.env.*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
frontend/coverage/
frontend/.nyc_output/

# --- LOGS ---
*.log
logs/
*.log.*

# --- IDEs Y EDITORES ---
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# --- SISTEMAS DE CONTROL ---
.git/
.gitattributes

# --- DEPENDENCIAS ---
*.lock
# excepto package-lock.json y Pipfile.lock que SÍ deben ir
!frontend/package-lock.json
!backend/Pipfile.lock

# --- ARCHIVOS TEMPORALES ---
tmp/
temp/
*.tmp
*.temp
.cache/