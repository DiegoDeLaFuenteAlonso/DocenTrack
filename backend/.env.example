# ==========================================
# DocenTrack - Variables de Entorno
# ==========================================
# Copiar este archivo a .env y rellenar con valores reales
# NUNCA subir .env a GitHub

# --- DJANGO CORE ---
DEBUG=True
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-de-50-caracteres-minimo

# --- BASE DE DATOS ---
# SQLite (desarrollo local):
DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL (producción Render - se configura automático):
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- HOSTS PERMITIDOS ---
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# --- CONFIGURACIÓN JWT ---
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# --- EMAIL (opcional) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Para producción:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu-email@gmail.com
# EMAIL_HOST_PASSWORD=tu-app-password

# --- OTROS ---
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1
